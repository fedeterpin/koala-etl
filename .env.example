# --- Base de datos ---
DATABASE_URL=postgresql+asyncpg://koala:koala@localhost:5432/koala

# --- S3 / MinIO ---
S3_ENDPOINT_URL=http://localhost:9000   # vacío en AWS real
S3_BUCKET=koala-files
S3_ACCESS_KEY=koala
S3_SECRET_KEY=koala-secret
S3_REGION=us-east-1

# --- Auth ---
JWT_SECRET=cambiame-en-produccion
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800

# --- Cifrado de credenciales Botmaker (Fernet) ---
# Generar con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIALS_ENCRYPTION_KEY=

# --- App ---
APP_BASE_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173
ETL_DEFAULT_WINDOW_DAYS=30
LOG_LEVEL=INFO
